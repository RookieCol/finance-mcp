# Copy to .env and fill in. All variables here are read by finance_mcp/config.py
# (pydantic-settings) — startup fails fast if a required one is missing.

# Required
DATABASE_URL=postgresql+psycopg://finance:finance@localhost:5432/finance

# Optional
LOG_LEVEL=INFO
UI_HOST=0.0.0.0
UI_PORT=8000
OTEL_EXPORTER_OTLP_ENDPOINT=

# --- Stage 7: proactive scheduler (internal fallback delivery) ---
# Webhook URL for alert/digest delivery (Slack/Discord incoming webhook, or
# any endpoint accepting {"text": "..."}). If unset, findings are logged
# instead of sent anywhere — the scheduler still runs, nothing is dropped.
NOTIFIER_WEBHOOK_URL=
# Current cash balance, used for runway calculations.
SCHEDULER_CASH_BALANCE=0
SCHEDULER_ALERT_CHECK_HOUR_UTC=8
SCHEDULER_DIGEST_DAY_OF_WEEK=mon
SCHEDULER_DIGEST_HOUR_UTC=9

# --- Optional: docker-compose.hermes-dev.yml (--profile hermes-dev) ---
# Live Hermes chat integration for local dev — routes to OpenRouter
# directly (docker/hermes/config.yaml). Set a per-key spending cap on
# this key in the OpenRouter dashboard (API Keys) rather than relying on
# any local budget enforcement — see docs/observability.md.
OPENROUTER_API_KEY=

# --- Optional: send this service's own OpenTelemetry traces to a free
# Langfuse Cloud project (https://cloud.langfuse.com). Separate from
# Hermes' own LLM cost/tracing, which is OpenRouter's "Broadcast to
# Langfuse" dashboard setting, not an env var here. See docs/observability.md.
# OTEL_EXPORTER_OTLP_ENDPOINT=https://cloud.langfuse.com/api/public/otel/v1/traces
# OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic <base64 of public_key:secret_key>,x-langfuse-ingestion-version=4
