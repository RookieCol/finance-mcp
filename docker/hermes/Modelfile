# Qwen2.5:3b-instruct supports up to 128K context natively, but Ollama
# serves it at a 32K default unless told otherwise — Hermes Agent
# requires at least 64K for its multi-step tool-calling working memory.
# This tags a variant with that raised, so `ollama pull` gets the base
# weights (no re-download) and `ollama create` just sets the parameter.
#
# 3B, not 7B: a 7B model's weights (~4.5GB) plus its KV cache at 64K
# context (~3.7GB) need ~8.2GB, more than fits in Docker Desktop's
# default 7.75GB VM even with nothing else running — the llama.cpp
# runner gets silently OOM-killed ("llama runner process has
# terminated", no useful error). 3B's smaller weights and per-layer KV
# footprint fit comfortably alongside the rest of this compose stack
# (Langfuse, the app itself, etc.) on that same default VM size.
# Bump this to qwen2.5:7b-instruct if you've raised Docker Desktop's
# memory limit (Settings → Resources → Memory) to ~16GB or more.
FROM qwen2.5:3b-instruct
PARAMETER num_ctx 65536
