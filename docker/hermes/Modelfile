# Qwen2.5:7b-instruct supports up to 128K context natively, but Ollama
# serves it at a 32K default unless told otherwise — Hermes Agent
# requires at least 64K for its multi-step tool-calling working memory.
# This tags a variant with that raised, so `ollama pull` gets the base
# weights (no re-download) and `ollama create` just sets the parameter.
FROM qwen2.5:7b-instruct
PARAMETER num_ctx 65536
